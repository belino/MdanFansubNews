<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MDAN_MAUI.SettingsPage"
             Title="Configurações"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25" VerticalOptions="FillAndExpand">
            
            <!-- Header Banner -->
            <Frame BackgroundColor="{StaticResource Primary}" BorderColor="Transparent" CornerRadius="12" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="CONFIGURAÇÕES" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="Personalize sua experiência de notícias" FontSize="12" TextColor="#D1FAE5" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Notifications Section -->
            <Label Text="Notificações" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}" Margin="0,10,0,0"/>
            <Frame CornerRadius="12" Padding="15" BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Notificações de Lançamentos" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
                            <Label Text="Receba alertas de novos animes e mangás" FontSize="12" TextColor="{StaticResource Gray500}"/>
                        </VerticalStackLayout>
                        <Switch x:Name="NotificationSwitch" Grid.Column="1" IsToggled="True" Toggled="OnNotificationToggled" ThumbColor="{StaticResource Primary}" OnColor="{StaticResource Secondary}"/>
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,5"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Frequência de Verificação" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
                        <Picker x:Name="IntervalPicker" SelectedIndexChanged="OnIntervalChanged">
                            <Picker.Items>
                                <x:String>15 minutos</x:String>
                                <x:String>30 minutos</x:String>
                                <x:String>1 hora</x:String>
                                <x:String>2 horas</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <Button Text="Testar Notificação Agora"
                            Clicked="OnTestNotificationClicked"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource Primary}"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            Margin="0,10,0,0"
                            HeightRequest="44"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Appearance Section -->
            <Label Text="Aparência" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
            <Frame CornerRadius="12" Padding="15" BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Tema do Aplicativo" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
                    <Picker x:Name="ThemePicker" SelectedIndexChanged="OnThemeChanged">
                        <Picker.Items>
                            <x:String>Padrão do Sistema</x:String>
                            <x:String>Modo Claro</x:String>
                            <x:String>Modo Escuro</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Frame>

            <!-- About Section -->
            <Label Text="Sobre o MDAN" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
            <Frame CornerRadius="12" Padding="15" BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="MDAN Fansub Mobile" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
                    <Label Text="Versão 2.0.0 (MAUI Revamp)" FontSize="12" TextColor="{StaticResource Gray500}"/>
                    <Label Text="O MDAN é um grupo focado em legendar animes, mangás, dramas e trilhas sonoras originais (OST) com a melhor qualidade possível para a comunidade lusófona." FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Gray300}}" TextType="Text"/>
                    
                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,5"/>
                    
                    <Label Text="Desenvolvido por NutCoders / MDAN Fansub." FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
