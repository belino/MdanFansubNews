<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MDAN_MAUI.DetailsPage"
             Title="Detalhes do Lançamento"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">
                
                <!-- Main Header Image -->
                <Grid HeightRequest="250" BackgroundColor="{StaticResource Gray900}">
                    <Image x:Name="DetailImage" Aspect="AspectFill"/>
                    <BoxView Color="Black" Opacity="0.45" VerticalOptions="Fill" HorizontalOptions="Fill"/>
                    
                    <!-- Back Button overlay -->
                    <Button Text="✕" 
                            Clicked="OnBackClicked" 
                            TextColor="White" 
                            BackgroundColor="#80000000" 
                            CornerRadius="20"
                            WidthRequest="40" 
                            HeightRequest="40" 
                            HorizontalOptions="Start" 
                            VerticalOptions="Start" 
                            Margin="15,15,0,0"/>

                    <!-- Category Badge -->
                    <Frame x:Name="CategoryBadge"
                           BorderColor="Transparent" 
                           BackgroundColor="{StaticResource Primary}" 
                           CornerRadius="15" 
                           Padding="10,4" 
                           HorizontalOptions="End" 
                           VerticalOptions="End" 
                           Margin="15">
                        <Label x:Name="CategoryText" Text="Categoria" FontSize="11" TextColor="White" FontAttributes="Bold"/>
                    </Frame>
                </Grid>

                <VerticalStackLayout Padding="20" Spacing="15">
                    
                    <!-- Post Title -->
                    <Label x:Name="TitleText" 
                           Text="Título do Lançamento" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                           LineBreakMode="WordWrap"/>

                    <!-- Date and Publisher Info -->
                    <Grid ColumnDefinitions="*, Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                            <Label Text="🕒" FontSize="12" VerticalOptions="Center"/>
                            <Label x:Name="DateText" Text="Publicado em..." FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" Text="MDAN Fansub" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" Margin="0,5"/>

                    <!-- Post Description -->
                    <Label x:Name="DescriptionText" 
                           Text="Descrição detalhada..." 
                           FontSize="15" 
                           LineHeight="1.4"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" 
                           TextType="Text"/>
                           
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Action Button Footer -->
        <Frame Grid.Row="1" 
               BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}" 
               BorderColor="Transparent" 
               CornerRadius="0" 
               Padding="15,10" 
               HasShadow="True">
            <Button x:Name="OpenBrowserButton"
                    Text="Ver no Navegador"
                    Clicked="OnOpenBrowserClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"/>
        </Frame>
    </Grid>
</ContentPage>
